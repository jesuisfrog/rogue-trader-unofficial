{{!-- partials/starship-overview.hbs --}}
<div class="starship-overview">

  {{!-- Power & Space budget --}}
  <div class="budget-row">
    <div class="budget-block {{#if powerOverload}}budget-danger{{/if}}">
      <span class="budget-label">Power</span>
      <div class="budget-bar-track">
        <div class="budget-bar power-bar"
             style="width: {{#if system.hull.powerCurrent}}{{min (divide (multiply powerUsed 100) system.hull.powerCurrent) 100}}{{else}}0{{/if}}%">
        </div>
      </div>
      <span class="budget-numbers">
        <span class="budget-used {{#if powerOverload}}overload{{/if}}">{{powerUsed}}</span>
        /
        <input type="number" name="system.hull.powerCurrent" value="{{system.hull.powerCurrent}}"
               class="budget-max-input" title="Power Generated" />
        generated
        <span class="budget-free {{#if powerOverload}}overload{{/if}}">
          ({{powerFree}} {{#if powerOverload}}OVERLOADED{{else}}free{{/if}})
        </span>
      </span>
    </div>
    <div class="budget-block">
      <span class="budget-label">Space</span>
      <div class="budget-bar-track">
        <div class="budget-bar space-bar"
             style="width: {{#if system.hull.spaceTotal}}{{min (divide (multiply spaceUsed 100) system.hull.spaceTotal) 100}}{{else}}0{{/if}}%">
        </div>
      </div>
      <span class="budget-numbers">
        <span class="budget-used">{{spaceUsed}}</span>
        /
        <input type="number" name="system.hull.spaceTotal" value="{{system.hull.spaceTotal}}"
               class="budget-max-input" title="Hull Space" />
        spaces
        <span class="budget-free">({{spaceFree}} free)</span>
      </span>
    </div>
  </div>

  {{!-- Quick weapon reference --}}
  <div class="overview-weapons-section">
    <h3 class="section-title">Weapon Summary</h3>
    {{#if allWeapons}}
    <table class="weapon-table ship-weapon-table">
      <thead>
        <tr>
          <th>Weapon</th>
          <th>Arc</th>
          <th>Type</th>
          <th>Str</th>
          <th>Damage</th>
          <th>Crit</th>
          <th>Range</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each allWeapons as |w|}}
        <tr>
          <td class="weapon-name">{{w.name}}</td>
          <td class="small-text">{{w.arcLabel}}</td>
          <td class="small-text {{#if (eq w.type 'lance')}}lance-type{{/if}}">
            {{#if (eq w.type "lance")}}Lance{{else}}Macro{{/if}}
          </td>
          <td>{{w.strength}}</td>
          <td>{{w.damage}}</td>
          <td>{{w.critRating}}</td>
          <td>{{w.range}} VU</td>
          <td>
            <button type="button" class="weapon-fire-btn vcb-btn"
                    data-arc="{{w.arc}}" data-index="{{w.index}}"
                    title="Fire {{w.name}}">
              <i class="fa-solid fa-crosshairs"></i>
            </button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="empty-list">No weapons installed. Add them in the Weapons tab.</p>
    {{/if}}
  </div>

  {{!-- Complications --}}
  <div class="complications-section">
    <h3 class="section-title">Complications</h3>
    <div class="complications-grid">
      <div class="complication-block">
        <label>Machine Spirit Oddity</label>
        <input type="text" name="system.complications.machineSpirit.name"
               value="{{system.complications.machineSpirit.name}}"
               placeholder="e.g. Wrothful, Ancient and Wise" />
        <textarea name="system.complications.machineSpirit.description"
                  rows="2" placeholder="Effects and description…">{{system.complications.machineSpirit.description}}</textarea>
      </div>
      <div class="complication-block">
        <label>Past History</label>
        <input type="text" name="system.complications.pastHistory.name"
               value="{{system.complications.pastHistory.name}}"
               placeholder="e.g. Wrested from a Space Hulk" />
        <textarea name="system.complications.pastHistory.description"
                  rows="2" placeholder="Effects and description…">{{system.complications.pastHistory.description}}</textarea>
      </div>
    </div>
  </div>

  {{!-- Endeavour tracker --}}
  <div class="endeavour-section">
    <h3 class="section-title">Current Endeavour</h3>
    <div class="endeavour-grid">
      <div class="endeavour-field">
        <label>Endeavour Name</label>
        <input type="text" name="system.endeavour.name"
               value="{{system.endeavour.name}}" placeholder="Name of this Endeavour" />
      </div>
      <div class="endeavour-field">
        <label>Objective</label>
        <input type="text" name="system.endeavour.objective"
               value="{{system.endeavour.objective}}" placeholder="e.g. Trade, Exploration, Military" />
      </div>
      <div class="endeavour-field">
        <label>Achievement Points</label>
        <div class="ap-row">
          <input type="number" name="system.endeavour.achievementPoints.value"
                 value="{{system.endeavour.achievementPoints.value}}" min="0" class="ap-input" />
          <span>/</span>
          <input type="number" name="system.endeavour.achievementPoints.max"
                 value="{{system.endeavour.achievementPoints.max}}" min="0" class="ap-input" />
        </div>
      </div>
    </div>
  </div>

</div>
