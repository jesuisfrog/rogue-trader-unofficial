{{!-- templates/items/item-sheet.hbs --}}
<form class="rt-sheet item-sheet item-type-{{item.type}}" autocomplete="off">

  <header class="item-sheet-header">
    <img class="item-img" src="{{item.img}}" data-edit="img" alt="{{item.name}}" />
    <div class="item-header-fields">
      <input class="item-name" type="text" name="name" value="{{item.name}}" placeholder="Item Name" />
      <span class="item-type-badge">{{item.type}}</span>
    </div>
  </header>

  <section class="item-sheet-body">

    {{!-- ── Weapon ──────────────────────────────────────────────────────── --}}
    {{#if (eq item.type "weapon")}}
    {{> "systems/rogue-trader-unofficial/templates/items/partials/weapon-fields.hbs"}}
    {{/if}}

    {{!-- ── Armour ───────────────────────────────────────────────────────── --}}
    {{#if (eq item.type "armour")}}
    {{> "systems/rogue-trader-unofficial/templates/items/partials/armour-fields.hbs"}}
    {{/if}}

    {{!-- ── Gear ─────────────────────────────────────────────────────────── --}}
    {{#if (eq item.type "gear")}}
    <div class="form-grid">
      <div class="form-group">
        <label>Quantity</label>
        <input type="number" name="system.quantity" value="{{system.quantity}}" min="1" />
      </div>
      <div class="form-group">
        <label>Weight (kg)</label>
        <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1" />
      </div>
      <div class="form-group">
        <label>Craftsmanship</label>
        <select name="system.craftsmanship">
          {{selectOptionsRT craftsmanships system.craftsmanship}}
        </select>
      </div>
      <div class="form-group">
        <label>Availability</label>
        <select name="system.availability">
          {{selectOptionsRT availabilities system.availability}}
        </select>
      </div>
    </div>
    {{/if}}

    {{!-- ── Skill ────────────────────────────────────────────────────────── --}}
    {{#if (eq item.type "skill")}}
    {{> "systems/rogue-trader-unofficial/templates/items/partials/skill-fields.hbs"}}
    {{/if}}

    {{!-- ── Talent ───────────────────────────────────────────────────────── --}}
    {{#if (eq item.type "talent")}}
    {{> "systems/rogue-trader-unofficial/templates/items/partials/talent-fields.hbs"}}
    {{/if}}

    {{!-- ── Psychic Power ───────────────────────────────────────────────── --}}
    {{#if (eq item.type "psychicPower")}}
    {{> "systems/rogue-trader-unofficial/templates/items/partials/psychic-fields.hbs"}}
    {{/if}}

    {{!-- ── Cybernetic ──────────────────────────────────────────────────── --}}
    {{#if (eq item.type "cybernetic")}}
    <div class="form-grid">
      <div class="form-group">
        <label>Type</label>
        <select name="system.type">
          <option value="limb" {{#if (eq system.type "limb" )}}selected{{/if}}>Limb / Body Part</option>
          <option value="sensory" {{#if (eq system.type "sensory" )}}selected{{/if}}>Sensory</option>
          <option value="cranial" {{#if (eq system.type "cranial" )}}selected{{/if}}>Cranial</option>
          <option value="other" {{#if (eq system.type "other" )}}selected{{/if}}>Other</option>
        </select>
      </div>
      <div class="form-group">
        <label>Craftsmanship</label>
        <select name="system.craftsmanship">
          {{selectOptionsRT craftsmanships system.craftsmanship}}
        </select>
      </div>
    </div>
    {{/if}}

    {{!-- ── Shared description (all types) ───────────────────────────────── --}}
    <div class="item-description">
      <label>Description</label>
      <div class="editor-wrapper">
        {{editor system.description target="system.description"
        button=true owner=owner editable=editable}}
      </div>
    </div>

  </section>

</form>