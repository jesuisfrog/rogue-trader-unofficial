{{!-- partials/talent-fields.hbs --}}
<div class="form-grid talent-fields">

  <div class="form-group full-width">
    <label>Prerequisites</label>
    <input type="text" name="system.prerequisites" value="{{system.prerequisites}}"
           placeholder="e.g. BS 35, Ballistic Skill Training" />
  </div>

  <div class="form-group full-width">
    <label>Source / Page</label>
    <input type="text" name="system.source" value="{{system.source}}"
           placeholder="e.g. Core Rulebook p.94" />
  </div>

</div>
